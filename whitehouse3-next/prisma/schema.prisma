  status              String?
  content             String?   @db.Text
  yesVotes            Int       @default(0) @map("yes_votes")
  noVotes             Int       @default(0) @map("no_votes")
  sentAt              DateTime? @map("sent_at")
  approvedAt          DateTime? @map("approved_at")
  declinedAt          DateTime? @map("declined_at")
