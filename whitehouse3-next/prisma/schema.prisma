  volumeCount   Int?      @map("volume_count")
  changePercent Float     @default(0) @map("change_percent")
  change        Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  priorityId Int      @map("priority_id")
  priority   Priority @relation(fields: [priorityId], references: [id])

  @@index([priorityId])
  @@index([dateYear, dateMonth, dateDay])
  @@map("priority_charts")
}

model UserChart {
  id          Int      @id @default(autoincrement())
  dateYear    Int      @map("date_year")
  dateMonth   Int      @map("date_month")
  dateDay     Int      @map("date_day")
  position    Int?
  upCount     Int?     @map("up_count")
  downCount   Int?     @map("down_count")
  volumeCount Int?     @map("volume_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([dateYear, dateMonth, dateDay])
  @@map("user_charts")
}

model Unsubscribe {
  id                       Int      @id @default(autoincrement())
  email                    String?
  reason                   String?  @db.Text
  isCommentsSubscribed     Boolean  @default(false) @map("is_comments_subscribed")
  isVotesSubscribed        Boolean  @default(false) @map("is_votes_subscribed")
  isNewsletterSubscribed   Boolean  @default(false) @map("is_newsletter_subscribed")
  isPointChangesSubscribed Boolean  @default(false) @map("is_point_changes_subscribed")
  isMessagesSubscribed     Boolean  @default(false) @map("is_messages_subscribed")
  isFollowersSubscribed    Boolean  @default(true) @map("is_followers_subscribed")
  isFinishedSubscribed     Boolean  @default(true) @map("is_finished_subscribed")
  isAdminSubscribed        Boolean  @default(false) @map("is_admin_subscribed")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  @@map("unsubscribes")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(50)
  subject   String?  @db.VarChar(150)
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("email_templates")
}

model Page {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(100)
  shortName String?  @map("short_name") @db.VarChar(30)
  linkName  String?  @map("link_name") @db.VarChar(60)
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}
